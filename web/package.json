{
  "name": "pr-tool-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "preview": "vite preview",
    "lint": "node ./src/varlockSync.js && concurrently -c \"#c596c7\",\"#676778\",\"#4b32c3\",\"#fafafa\" --kill-others-on-fail \"npm:lint:*\"",
    "lint:prettier": "prettier --check .",
    "lint:svelte-check": "svelte-check --fail-on-warnings --tsgo",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:stylelint": "stylelint --max-warnings=0 \"src/**/*.{css,svelte}\"",
    "format": "eslint --fix && stylelint --fix \"src/**/*.{css,svelte}\" && prettier --write .",
    "prepare": "husky || true",
    "build": "vite build",
    "test": "playwright test",
    "playwright:ui": "playwright test --ui"
  },
  "lint-staged": {
    "*.{ts,svelte}": [
      "svelte-check --fail-on-warnings --diagnostic-sources \"js,svelte\""
    ],
    "*.{ts,svelte,js,cjs,mjs}": [
      "eslint --max-warnings 0 --no-ignore"
    ],
    "*.{ts,js,svelte,css,scss,json,html}": [
      "prettier --check"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/svelte": "^5.3.1",
    "@types/js-gravatar": "^1.1.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.8.0",
    "@typescript/native-preview": "7.0.0-dev.20260515.1",
    "@varlock/vite-integration": "^1.1.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "js-gravatar": "^1.1.3",
    "lint-staged": "^17.0.4",
    "lodash-es": "^4.18.1",
    "network-information-types": "^0.1.1",
    "postcss": "^8.5.14",
    "postcss-html": "^1.8.1",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rxjs": "^7.8.2",
    "stylelint": "^17.11.1",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-prettier": "^5.0.3",
    "svelte": "5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "varlock": "^1.2.0",
    "vite": "^8.0.13",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
